m_hill, caminho = hill_climbing(inicial)
m_bmc, caminho_bmc = busca_melhor_escolha(inicial)

if m_hill is not None:
    print("| Objetivo Encontrado!")
    print(f"| Caminho percorrido: {caminho}")
    print(f"{m_hill}")

if m_bmc is not None:
    print("| Busca Melhor Escolha")
