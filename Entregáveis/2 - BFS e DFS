#classe -> ajuda a manejar depois ao longo do código
class Estado:
    def __init__(self, valor, pai=None):
        self.valor = valor
        self.pai = pai

#função para contruir o caminho com base no pai daquele estado -> recursivo
def caminho(estado):
    caminho = []
    while estado is not None:
        caminho.append(estado.valor)
        estado = estado.pai
    caminho.reverse()   #grava a lista de trás pra frente
    return caminho

