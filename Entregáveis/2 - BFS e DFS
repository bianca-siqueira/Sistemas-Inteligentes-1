def DFS(inicial, obj, tamanho):

    #inicialização
    abertos = []
    abertos.append(Estado(inicial))
    fechados = set()

    while abertos != []:

        x = abertos.pop()

        #se chegou no objetivo, retorna o caminho feito
        if x.valor == obj:
            return caminho(x)

        fechados.add(x.valor)

        #gerando os filhos de x
        for w in range(tamanho):
            if(G[x.valor][w]==1 and w not in fechados and w not in abertos):
                abertos.append(Estado(w, x))

    return []

